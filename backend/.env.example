# Boardify Backend — Environment Variables
# Copy this file to .env and fill in your Neon DB connection string.
# NEVER commit the actual .env file to git.

# Neon PostgreSQL connection string
# Get this from your Neon project dashboard → Connection Details
DATABASE_URL=postgresql://username:password@ep-xxx-xxx.us-east-2.aws.neon.tech/boardify?sslmode=require

# Port for the Express server
PORT=5000

# Frontend URL for CORS (your deployed frontend or localhost)
FRONTEND_URL=http://localhost:5173
